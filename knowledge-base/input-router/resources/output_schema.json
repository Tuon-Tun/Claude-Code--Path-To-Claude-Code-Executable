{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prd-creator.local/schemas/input-router-output.schema.json",
  "title": "Input Router Output",
  "description": "Structured brief produced by the input-router skill before PRD drafting.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "Delivery_Mode",
    "Output_Artifacts",
    "Active_Sections",
    "Clarification_Confirmed",
    "Domain_Name",
    "Feature_Name",
    "Input_Type",
    "Core_Objective",
    "Problem_Statement",
    "JTBD_Candidates",
    "Target_Users",
    "Epic_Candidates",
    "Primary_User_Story",
    "User_Story_Candidates",
    "User_Flow",
    "Business_Logic_and_Rules",
    "Functional_Requirements",
    "Non_Functional_Requirements",
    "Success_Metrics",
    "UI_UX_Requirements",
    "API_or_Integration_Notes",
    "Diagram_Requirements",
    "Assumptions",
    "Missing_Information"
  ],
  "properties": {
    "Delivery_Mode": {
      "type": "string",
      "description": "How the user wants the PRD workflow to run.",
      "enum": [
        "IDE_FULL_PIPELINE",
        "CHAT_TEXT_ONLY"
      ]
    },
    "Output_Artifacts": {
      "type": "array",
      "description": "Expected final outputs for the selected delivery mode.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "Text Response",
          "Markdown File",
          "DOCX File"
        ]
      }
    },
    "Active_Sections": {
      "type": "array",
      "description": "PRD sections the user has confirmed they want included. Sections not listed here are skipped during drafting.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "Problem Statement",
          "JTBD",
          "Goals & Success Metrics",
          "Assumptions & Open Questions",
          "Feature Epics & User Stories",
          "Business Rules",
          "Process Diagrams",
          "Use Case Specifications",
          "Functional Requirements",
          "Non-Functional Requirements",
          "UI/UX Specifications",
          "API / Technical Specs"
        ]
      }
    },
    "Clarification_Confirmed": {
      "type": "boolean",
      "description": "Set to true only after the user has reviewed, corrected, and explicitly approved the structured JSON in the Step 1.5 clarification gate. Never set to true by the model without user confirmation."
    },
    "Domain_Name": {
      "type": "string",
      "description": "Lowercase kebab-case domain slug.",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "examples": ["loyalty-wallet", "payment-gateway", "user-profile"]
    },
    "Feature_Name": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable feature name inferred from the input."
    },
    "Input_Type": {
      "type": "string",
      "enum": [
        "JTBDs",
        "Wireframe Notes",
        "Business Requirements",
        "Mixed"
      ]
    },
    "Core_Objective": {
      "$ref": "#/$defs/non_empty_or_needs_clarification"
    },
    "Problem_Statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["User_Problem", "Business_Problem"],
      "properties": {
        "User_Problem": {
          "$ref": "#/$defs/non_empty_or_needs_clarification"
        },
        "Business_Problem": {
          "$ref": "#/$defs/non_empty_or_needs_clarification"
        }
      }
    },
    "JTBD_Candidates": {
      "type": "array",
      "description": "JTBD signals extracted from the input. Product Framing will refine and validate these before drafting.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "User_Type",
          "Situation",
          "Motivation",
          "Expected_Outcome"
        ],
        "properties": {
          "User_Type": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Situation": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Motivation": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Expected_Outcome": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          }
        }
      }
    },
    "Target_Users": {
      "$ref": "#/$defs/string_array"
    },
    "Epic_Candidates": {
      "$ref": "#/$defs/string_array"
    },
    "Primary_User_Story": {
      "$ref": "#/$defs/non_empty_or_needs_clarification"
    },
    "User_Story_Candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["Title", "Actor", "Action", "Value"],
        "properties": {
          "Title": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Actor": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Action": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Value": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          }
        }
      }
    },
    "User_Flow": {
      "$ref": "#/$defs/string_array"
    },
    "Business_Logic_and_Rules": {
      "$ref": "#/$defs/string_array"
    },
    "Functional_Requirements": {
      "$ref": "#/$defs/string_array"
    },
    "Non_Functional_Requirements": {
      "$ref": "#/$defs/string_array"
    },
    "Success_Metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["Metric", "Baseline", "Target"],
        "properties": {
          "Metric": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Baseline": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          },
          "Target": {
            "$ref": "#/$defs/non_empty_or_needs_clarification"
          }
        }
      }
    },
    "UI_UX_Requirements": {
      "$ref": "#/$defs/string_array"
    },
    "API_or_Integration_Notes": {
      "$ref": "#/$defs/string_array"
    },
    "Diagram_Requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "None",
          "Activity Diagram",
          "Sequence Diagram",
          "BPMN"
        ]
      }
    },
    "Assumptions": {
      "$ref": "#/$defs/string_array"
    },
    "Missing_Information": {
      "$ref": "#/$defs/string_array"
    }
  },
  "$defs": {
    "non_empty_or_needs_clarification": {
      "type": "string",
      "minLength": 1,
      "description": "Use [NEEDS_CLARIFICATION] when the source input does not provide this information."
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_or_needs_clarification"
      }
    }
  }
}
